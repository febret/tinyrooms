    "from pathlib import Path\n",
    "import duckdb\n",
    "import os\n",
    "\n",
    "ws_id = 'home'\n",
    "dbpath = Path(os.getcwd()).parent / \"data\" / f\"worldstate_{ws_id}.duckdb\"\n",
    "conn = duckdb.connect(dbpath)\n",
    "\n",
    "rooms_df = conn.execute(\"\"\"SELECT * FROM rooms\"\"\").df()\n",
    "display(rooms_df)"
   ]
