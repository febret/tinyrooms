#!/usr/bin/env python3
"""
make-icon: Generate a 64x64 PNG icon using Stable Diffusion 1.5.

Usage:
    make-icon <path.png> <description> [--style <style description>]
"""

import argparse
import sys
from collections import deque
from pathlib import Path


def parse_args():
    parser = argparse.ArgumentParser(
        description="Generate a 64x64 PNG icon using a local text-to-image model."
    )
    parser.add_argument("path", type=Path, help="Output PNG file path")
    parser.add_argument("description", help="Content description for the icon")
    parser.add_argument("--style", default="", help="Optional style description")
    return parser.parse_args()


def build_prompt(description: str, style: str) -> str:
    base = (
        f"illustration, {description}, "
        "single object centered, high quality, detailed, transparent background"
    )
    if style:
        base += f", {style}"
    return base


def remove_background(image):
    from PIL import ImageFilter

    rgba = image.convert("RGBA")
    width, height = rgba.size
    pixels = rgba.load()

    border = []
    for x in range(width):
        border.append(pixels[x, 0][:3])
        border.append(pixels[x, height - 1][:3])
    for y in range(1, height - 1):
        border.append(pixels[0, y][:3])
        border.append(pixels[width - 1, y][:3])

    border_sorted_r = sorted(c[0] for c in border)
    border_sorted_g = sorted(c[1] for c in border)
    border_sorted_b = sorted(c[2] for c in border)
    mid = len(border) // 2
    bg = (
        border_sorted_r[mid],
        border_sorted_g[mid],
        border_sorted_b[mid],
    )

    def color_distance(rgb):
        dr = rgb[0] - bg[0]
        dg = rgb[1] - bg[1]
        db = rgb[2] - bg[2]
        return (dr * dr + dg * dg + db * db) ** 0.5

    hard_threshold = 52.0
    soft_threshold = 88.0

    visited = [[False] * height for _ in range(width)]
    queue = deque()

    def enqueue_if_background(x, y):
        if visited[x][y]:
            return
        if color_distance(pixels[x, y][:3]) <= hard_threshold:
            visited[x][y] = True
            queue.append((x, y))

    for x in range(width):
        enqueue_if_background(x, 0)
        enqueue_if_background(x, height - 1)
    for y in range(height):
        enqueue_if_background(0, y)
        enqueue_if_background(width - 1, y)

    while queue:
        x, y = queue.popleft()
        if x > 0:
            enqueue_if_background(x - 1, y)
        if x + 1 < width:
            enqueue_if_background(x + 1, y)
        if y > 0:
            enqueue_if_background(x, y - 1)
        if y + 1 < height:
            enqueue_if_background(x, y + 1)

    for x in range(width):
        for y in range(height):
            r, g, b, a = pixels[x, y]
            if visited[x][y]:
                pixels[x, y] = (r, g, b, 0)
                continue
            dist = color_distance((r, g, b))
            if dist <= hard_threshold:
                pixels[x, y] = (r, g, b, 0)
            elif dist < soft_threshold:
                alpha = int(255 * (dist - hard_threshold) / (soft_threshold - hard_threshold))
                pixels[x, y] = (r, g, b, max(0, min(255, alpha)))
            else:
                pixels[x, y] = (r, g, b, a)

    alpha = rgba.split()[3].filter(ImageFilter.GaussianBlur(radius=0.8))
    rgba.putalpha(alpha)
    return rgba


def generate_icon(output_path: Path, description: str, style: str):
    print("Loading model (this may take a minute on first run)...")

    import torch
    from diffusers import StableDiffusionPipeline
    from PIL import Image

    device = "cuda" if torch.cuda.is_available() else "cpu"
    dtype = torch.float16 if device == "cuda" else torch.float32

    if device == "cpu":
        print("WARNING: No CUDA GPU detected, running on CPU (will be very slow).")

    model_id = "runwayml/stable-diffusion-v1-5"
    pipe = StableDiffusionPipeline.from_pretrained(
        model_id,
        torch_dtype=dtype,
        safety_checker=None,
        requires_safety_checker=False,
    )
    pipe = pipe.to(device)

    if device == "cuda":
        pipe.enable_attention_slicing()

    prompt = build_prompt(description, style)
    negative_prompt = (
        "blurry, low quality, text, watermark, background, scenery, room, landscape"
    )

    print(f"Generating icon: {prompt!r}")
    result = pipe(
        prompt=prompt,
        negative_prompt=negative_prompt,
        width=512,
        height=512,
        num_inference_steps=20,
        guidance_scale=7.5,
    )

    image: Image.Image = result.images[0]
    icon = remove_background(image).resize((64, 64), Image.LANCZOS)

    output_path.parent.mkdir(parents=True, exist_ok=True)
    icon.save(output_path, "PNG")
    print(f"Icon saved to: {output_path}")


def main():
    args = parse_args()

    if not args.path.suffix.lower() == ".png":
        print(f"Error: output path must end with .png, got: {args.path}", file=sys.stderr)
        sys.exit(1)

    try:
        generate_icon(args.path, args.description, args.style)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
