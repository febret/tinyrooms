#!/usr/bin/env python3
"""
make-image: Generate PNG assets with configurable output size.

Usage:
    make-image <path.png> --size <WxH> [--description TEXT | --descriptors-json JSON]
"""

import argparse
import json
import sys
from collections import deque
from pathlib import Path


def parse_args():
    parser = argparse.ArgumentParser(description="Generate PNG images with configurable output size.")
    parser.add_argument("path", type=Path, help="Output PNG file path")
    parser.add_argument("--size", default="64x64", help="Output size in WxH format, e.g. 64x128")
    parser.add_argument("--description", default="", help="Prompt description")
    parser.add_argument("--descriptors-json", default="", help="Descriptor dictionary as JSON")
    parser.add_argument("--style", default="", help="Optional style description")
    parser.add_argument("--border-color", default="", help="Optional outline color (#RRGGBB)")
    parser.add_argument("--glow-color", default="", help="Optional glow color (#RRGGBB)")
    return parser.parse_args()


def build_prompt(description: str, descriptors: dict[str, str], style: str) -> str:
    if not description and descriptors:
        base = (
            "full body character sticker, simple clean line art, transparent background, "
            f"hair color {descriptors.get('hair_color', 'black')}, "
            f"skin color {descriptors.get('skin_color', 'olive')}, "
            f"{descriptors.get('body_adjective', 'athletic')} build, "
            f"wearing {descriptors.get('clothing_material_or_color', 'dark linen')} "
            f"{descriptors.get('clothing', 'cloak')}"
        )
        base = f"illustration, {base}, centered, game sprite, high contrast silhouette"
    else:
        if not description:
            description = "single centered object"
        base = f"illustration, {description}, single object centered, high quality, detailed, transparent background"
    if style:
        base += f", {style}"
    return base


def _hex_to_rgba(value: str, alpha: int = 255):
    value = value.strip().lstrip("#")
    if len(value) == 3:
        value = "".join([c * 2 for c in value])
    if len(value) != 6:
        raise ValueError(f"invalid hex color: {value}")
    return (int(value[0:2], 16), int(value[2:4], 16), int(value[4:6], 16), alpha)


def remove_background(image):
    from PIL import ImageFilter

    rgba = image.convert("RGBA")
    width, height = rgba.size
    pixels = rgba.load()

    border = []
    for x in range(width):
        border.append(pixels[x, 0][:3])
        border.append(pixels[x, height - 1][:3])
    for y in range(1, height - 1):
        border.append(pixels[0, y][:3])
        border.append(pixels[width - 1, y][:3])

    border_sorted_r = sorted(c[0] for c in border)
    border_sorted_g = sorted(c[1] for c in border)
    border_sorted_b = sorted(c[2] for c in border)
    mid = len(border) // 2
    bg = (
        border_sorted_r[mid],
        border_sorted_g[mid],
        border_sorted_b[mid],
    )

    def color_distance(rgb):
        dr = rgb[0] - bg[0]
        dg = rgb[1] - bg[1]
        db = rgb[2] - bg[2]
        return (dr * dr + dg * dg + db * db) ** 0.5

    hard_threshold = 52.0
    soft_threshold = 88.0

    visited = [[False] * height for _ in range(width)]
    queue = deque()

    def enqueue_if_background(x, y):
        if visited[x][y]:
            return
        if color_distance(pixels[x, y][:3]) <= hard_threshold:
            visited[x][y] = True
            queue.append((x, y))

    for x in range(width):
        enqueue_if_background(x, 0)
        enqueue_if_background(x, height - 1)
    for y in range(height):
        enqueue_if_background(0, y)
        enqueue_if_background(width - 1, y)

    while queue:
        x, y = queue.popleft()
        if x > 0:
            enqueue_if_background(x - 1, y)
        if x + 1 < width:
            enqueue_if_background(x + 1, y)
        if y > 0:
            enqueue_if_background(x, y - 1)
        if y + 1 < height:
            enqueue_if_background(x, y + 1)

    for x in range(width):
        for y in range(height):
            r, g, b, a = pixels[x, y]
            if visited[x][y]:
                pixels[x, y] = (r, g, b, 0)
                continue
            dist = color_distance((r, g, b))
            if dist <= hard_threshold:
                pixels[x, y] = (r, g, b, 0)
            elif dist < soft_threshold:
                alpha = int(255 * (dist - hard_threshold) / (soft_threshold - hard_threshold))
                pixels[x, y] = (r, g, b, max(0, min(255, alpha)))
            else:
                pixels[x, y] = (r, g, b, a)

    alpha = rgba.split()[3].filter(ImageFilter.GaussianBlur(radius=0.8))
    rgba.putalpha(alpha)
    return rgba


def resize_to_canvas(image, target_w: int, target_h: int):
    from PIL import Image

    sprite = image.convert("RGBA")
    bbox = sprite.getbbox()
    if bbox:
        sprite = sprite.crop(bbox)

    scale = min(target_w / max(1, sprite.width), target_h / max(1, sprite.height))
    new_size = (max(1, int(sprite.width * scale)), max(1, int(sprite.height * scale)))
    sprite = sprite.resize(new_size, Image.LANCZOS)

    canvas = Image.new("RGBA", (target_w, target_h), (0, 0, 0, 0))
    x = (target_w - sprite.width) // 2
    if target_h > target_w:
        y = target_h - sprite.height
    else:
        y = (target_h - sprite.height) // 2
    canvas.alpha_composite(sprite, (x, y))
    return canvas


def apply_effects(image, border_color: str, glow_color: str):
    from PIL import Image, ImageFilter

    base = image.convert("RGBA")
    alpha = base.split()[3]
    combined = Image.new("RGBA", base.size, (0, 0, 0, 0))
    if glow_color:
        glow_mask = alpha.filter(ImageFilter.GaussianBlur(radius=3))
        glow = Image.new("RGBA", base.size, _hex_to_rgba(glow_color, 150))
        glow.putalpha(glow_mask)
        combined.alpha_composite(glow)
    if border_color:
        outline_mask = alpha.filter(ImageFilter.MaxFilter(size=5))
        outline = Image.new("RGBA", base.size, _hex_to_rgba(border_color, 210))
        outline.putalpha(outline_mask)
        combined.alpha_composite(outline)
    combined.alpha_composite(base)
    return combined


def parse_size(size: str) -> tuple[int, int]:
    normalized = str(size).strip().lower()
    parts = normalized.split("x")
    if len(parts) != 2:
        raise ValueError("size must be in WxH format, e.g. 256x256")
    try:
        width = int(parts[0].strip())
        height = int(parts[1].strip())
    except ValueError as err:
        raise ValueError("size must use integer dimensions, e.g. 256x256") from err
    if width <= 0 or height <= 0:
        raise ValueError("size dimensions must be positive integers")
    return width, height


def _model_generation_size(target_w: int, target_h: int) -> tuple[int, int]:
    model_w = min(1024, max(256, target_w * 4))
    model_h = min(1024, max(256, target_h * 4))
    return model_w, model_h


def generate_image(
    output_path: Path,
    size: tuple[int, int],
    description: str,
    descriptors: dict[str, str],
    style: str,
    border_color: str,
    glow_color: str,
):
    import torch
    from diffusers import StableDiffusionPipeline

    target_w, target_h = size
    device = "cuda" if torch.cuda.is_available() else "cpu"
    dtype = torch.float16 if device == "cuda" else torch.float32
    if device == "cpu":
        print("WARNING: No CUDA GPU detected, running on CPU (slow).", file=sys.stderr)

    model_id = "runwayml/stable-diffusion-v1-5"
    pipe = StableDiffusionPipeline.from_pretrained(
        model_id,
        torch_dtype=dtype,
        safety_checker=None,
        requires_safety_checker=False,
    ).to(device)
    if device == "cuda":
        pipe.enable_attention_slicing()

    prompt = build_prompt(description, descriptors, style)
    negative_prompt = "blurry, low quality, text, watermark, background, scenery, logo, noisy"
    model_w, model_h = _model_generation_size(target_w, target_h)
    result = pipe(
        prompt=prompt,
        negative_prompt=negative_prompt,
        width=model_w,
        height=model_h,
        num_inference_steps=24,
        guidance_scale=7.5,
    )
    image = result.images[0]
    image = remove_background(image)
    image = resize_to_canvas(image, target_w, target_h)
    image = apply_effects(image, border_color, glow_color)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    image.save(output_path, "PNG")


def _run_generation(args) -> int:
    if args.path.suffix.lower() != ".png":
        print(f"Error: output path must end with .png: {args.path}", file=sys.stderr)
        return 1

    descriptors = {}
    if args.descriptors_json:
        try:
            loaded = json.loads(args.descriptors_json)
        except json.JSONDecodeError as err:
            print(f"Error: descriptors-json is invalid JSON: {err}", file=sys.stderr)
            return 1
        if not isinstance(loaded, dict):
            print("Error: descriptors-json must be a JSON object", file=sys.stderr)
            return 1
        descriptors = {str(k): str(v) for k, v in loaded.items()}

    if not args.description and not descriptors:
        print("Error: provide --description or --descriptors-json", file=sys.stderr)
        return 1

    try:
        size = parse_size(args.size)
    except ValueError as err:
        print(f"Error: {err}", file=sys.stderr)
        return 1

    generate_image(
        args.path,
        size,
        args.description,
        descriptors,
        args.style,
        args.border_color,
        args.glow_color,
    )
    return 0


def main():
    args = parse_args()
    try:
        sys.exit(_run_generation(args))
    except Exception as err:
        print(f"Error: {err}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
